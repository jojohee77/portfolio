// ============================================
// AgOffice ERD v0.1 - MariaDB
// ============================================
// 작성일: 2025-11-11
// 데이터베이스: MariaDB 10.6+
// 도구: dbdiagram.io
// 사용법: https://dbdiagram.io 에 접속하여 이 코드를 붙여넣기
// ============================================

Project AgOffice {
  database_type: 'MariaDB'
  Note: '''
  AgOffice - 마케팅 관리 플랫폼

  MariaDB 특화 사항:
  - UUID: CHAR(36) + UUID() 함수
  - ENUM 타입 활용
  - JSON 타입 (MariaDB 10.2+)
  - ON UPDATE CURRENT_TIMESTAMP
  - InnoDB 엔진
  - utf8mb4 문자셋
  '''
}

// ============================================
// 1. 조직/사용자 관리
// ============================================

Table users {
  id char(36) [pk, default: `UUID()`]
  name varchar(50) [not null]
  email varchar(100) [not null, unique]
  password_hash varchar(255) [not null]
  phone varchar(20)
  company_name varchar(100)
  position varchar(50)
  avatar_url varchar(500)
  two_factor_enabled boolean [not null, default: false]
  last_login_at datetime
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`, note: 'ON UPDATE CURRENT_TIMESTAMP']
  deleted_at datetime

  indexes {
    email [unique, name: 'idx_users_email']
    last_login_at [name: 'idx_users_last_login']
    deleted_at [name: 'idx_users_deleted']
  }

  Note: '시스템 사용자 (계정) - InnoDB, utf8mb4'
}

Table workspaces {
  id char(36) [pk, default: `UUID()`]
  name varchar(100) [not null]
  logo_url varchar(500)
  description text
  owner_id char(36) [not null, ref: > users.id]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    owner_id [name: 'idx_workspaces_owner']
  }

  Note: '워크스페이스 (다중 테넌트) - ON DELETE RESTRICT'
}

Table teams {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  name varchar(50) [not null]
  department varchar(50)
  lead_id char(36) [ref: > users.id]
  description text
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_teams_workspace']
    lead_id [name: 'idx_teams_lead']
    (workspace_id, name) [unique, name: 'idx_teams_workspace_name']
  }

  Note: '팀/부서 - CASCADE on workspace delete, SET NULL on lead delete'
}

Table workspace_users {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  user_id char(36) [not null, ref: > users.id]
  team_id char(36) [ref: > teams.id]
  role "ENUM('Owner', 'Admin', 'Manager', 'Member')" [not null, default: 'Member']
  status "ENUM('활성', '비활성', '초대중')" [not null, default: '초대중']
  joined_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_workspace_users_workspace']
    user_id [name: 'idx_workspace_users_user']
    team_id [name: 'idx_workspace_users_team']
    role [name: 'idx_workspace_users_role']
    status [name: 'idx_workspace_users_status']
    (workspace_id, user_id) [unique, name: 'idx_workspace_users_unique']
  }

  Note: 'N:N 중간 테이블 - CASCADE on both FK deletes'
}

// ============================================
// 2. 고객 및 계약 관리
// ============================================

Table customers {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  company_name varchar(100) [not null]
  contact_person varchar(50) [not null]
  phone varchar(20) [not null]
  address text
  region_sido varchar(20) [note: '서울, 경기 등']
  region_sigungu varchar(50) [note: '강남구, 수원시 등']
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_customers_workspace']
    company_name [name: 'idx_customers_company_name']
    (region_sido, region_sigungu) [name: 'idx_customers_region']
  }

  Note: '고객사 정보 - RESTRICT on workspace delete'
}

Table contracts {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  contract_number varchar(20) [not null, unique, note: 'CT-YYYY-###']
  contract_type "ENUM('월계약', '프로젝트', '연계약')" [not null]
  status "ENUM('신규', '연장', '확장')" [not null, default: '신규']
  customer_id char(36) [not null, ref: > customers.id]
  team_id char(36) [not null, ref: > teams.id]
  manager_id char(36) [not null, ref: > users.id]
  sales_rep_id char(36) [not null, ref: > users.id]
  services json [not null, note: 'JSON Array: ["SEO", "프리미엄", "하나탑"]']
  amount decimal(15,2) [not null, note: 'CHECK >= 0']
  posting_count int
  ad_cost_total decimal(15,2)
  ad_cost_monthly decimal(15,2)
  start_date date [not null]
  end_date date [not null, note: 'CHECK > start_date']
  is_expired boolean [not null, default: false, note: 'Trigger 자동 계산']
  registration_date date [not null, default: `CURRENT_DATE`]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_contracts_workspace']
    contract_number [unique, name: 'idx_contracts_number']
    customer_id [name: 'idx_contracts_customer']
    team_id [name: 'idx_contracts_team']
    manager_id [name: 'idx_contracts_manager']
    sales_rep_id [name: 'idx_contracts_sales_rep']
    (status, registration_date) [name: 'idx_contracts_status_regdate']
    (start_date, end_date) [name: 'idx_contracts_dates']
    is_expired [name: 'idx_contracts_expired']
  }

  Note: '고객 계약 - SET NULL on manager/sales delete'
}

// ============================================
// 3. 업무 관리
// ============================================

Table work_tasks {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  contract_id char(36) [not null, ref: > contracts.id]
  service_type varchar(50) [not null, note: 'SEO 최적화, SNS 마케팅 등']
  description text
  team_id char(36) [not null, ref: > teams.id]
  assignee_id char(36) [not null, ref: > users.id]
  target_keywords text [note: '쉼표 구분 or JSON']
  keyword_rank_limit int [note: 'CHECK 1-100']
  status "ENUM('진행중', '완료', '대기', '보류')" [not null, default: '대기']
  start_date date [not null]
  end_date date [not null, note: 'CHECK > start_date']
  notes text
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_worktasks_workspace']
    contract_id [name: 'idx_worktasks_contract']
    team_id [name: 'idx_worktasks_team']
    assignee_id [name: 'idx_worktasks_assignee']
    (status, created_at) [name: 'idx_worktasks_status_created']
    (start_date, end_date) [name: 'idx_worktasks_dates']
  }

  Note: '업무/작업 - CASCADE on contract delete, SET NULL on assignee delete'
}

Table keyword_assignments {
  id char(36) [pk, default: `UUID()`]
  work_task_id char(36) [not null, ref: > work_tasks.id]
  keyword_name varchar(100) [not null]
  assigned_team_id char(36) [not null, ref: > teams.id]
  assigned_user_id char(36) [not null, ref: > users.id]
  rank_limit int [note: 'CHECK 1-100']
  is_target_keyword boolean [not null, default: false]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    work_task_id [name: 'idx_keyword_assignments_task']
    keyword_name [name: 'idx_keyword_assignments_keyword']
    assigned_user_id [name: 'idx_keyword_assignments_user']
    assigned_team_id [name: 'idx_keyword_assignments_team']
  }

  Note: '키워드 할당 - CASCADE on task delete'
}

// ============================================
// 4. 키워드 및 포스팅 추적
// ============================================

Table keywords {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  name varchar(100) [not null]
  competition_level "ENUM('아주좋음', '좋음', '보통', '나쁨', '아주나쁨')"
  monthly_search_volume int [note: 'Naver API']
  monthly_post_volume int
  blog_saturation decimal(5,2) [note: '0-100%']
  is_target boolean [not null, default: false]
  is_tracking_active boolean [not null, default: true]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_keywords_workspace']
    (workspace_id, name) [unique, name: 'idx_keywords_workspace_name']
    competition_level [name: 'idx_keywords_competition']
    is_target [name: 'idx_keywords_target']
    is_tracking_active [name: 'idx_keywords_tracking']
  }

  Note: '키워드 마스터 - CASCADE on workspace delete'
}

Table postings {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  blog_url varchar(500) [not null, unique]
  customer_id char(36) [not null, ref: > customers.id]
  title varchar(200) [not null]
  keyword varchar(100) [not null, note: '또는 keyword_id FK']
  manager_id char(36) [not null, ref: > users.id]
  team_id char(36) [not null, ref: > teams.id]
  category "ENUM('신규', '재작업')" [not null, default: '신규']
  contract_threshold int [note: 'CHECK 1-100']
  current_rank int [note: 'CHECK 1-100 or NULL']
  rank_change int [note: 'Trigger 자동 계산']
  is_favorite boolean [not null, default: false]
  original_posting_id char(36) [ref: > postings.id, note: 'Self-reference']
  is_tracking_active boolean [not null, default: true]
  registered_date date [not null, default: `CURRENT_DATE`]
  last_checked datetime
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_postings_workspace']
    blog_url [unique, name: 'idx_postings_url']
    customer_id [name: 'idx_postings_customer']
    keyword [name: 'idx_postings_keyword']
    manager_id [name: 'idx_postings_manager']
    team_id [name: 'idx_postings_team']
    (category, current_rank) [name: 'idx_postings_category_rank']
    is_favorite [name: 'idx_postings_favorite']
    registered_date [name: 'idx_postings_registered']
    last_checked [name: 'idx_postings_last_checked']
    original_posting_id [name: 'idx_postings_original']
  }

  Note: '포스팅 추적 - SET NULL on FK deletes'
}

Table ranking_history {
  id char(36) [pk, default: `UUID()`]
  posting_id char(36) [not null, ref: > postings.id]
  checked_date date [not null]
  rank int [note: 'CHECK 1-100 or NULL (순위권 밖)']
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    posting_id [name: 'idx_ranking_history_posting']
    checked_date [name: 'idx_ranking_history_date']
    (posting_id, checked_date) [unique, name: 'idx_ranking_history_unique']
  }

  Note: '순위 이력 - CASCADE on posting delete'
}

// ============================================
// 5. 집계 테이블
// ============================================

Table revenue {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  year int [not null, note: 'CHECK >= 2020']
  half "ENUM('상반기', '하반기')"
  month int [not null, note: 'CHECK 1-12']
  service_name varchar(50) [not null, note: 'SEO, 프리미엄, 하나탑']
  team_id char(36) [ref: > teams.id]
  total_revenue decimal(15,2) [not null, default: 0, note: 'CHECK >= 0']
  contracts_count int [not null, default: 0, note: 'CHECK >= 0']
  posting_cost decimal(15,2)
  posting_count int
  avg_contract_value decimal(15,2) [note: '계산 필드']
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_revenue_workspace']
    (year, month) [name: 'idx_revenue_year_month']
    service_name [name: 'idx_revenue_service']
    team_id [name: 'idx_revenue_team']
    (workspace_id, year, month, service_name, team_id) [unique, name: 'idx_revenue_unique']
  }

  Note: '매출 집계 - Cron으로 생성/갱신'
}

Table performance {
  id char(36) [pk, default: `UUID()`]
  workspace_id char(36) [not null, ref: > workspaces.id]
  year int [not null, note: 'CHECK >= 2020']
  half "ENUM('상반기', '하반기')"
  month int [not null, note: 'CHECK 1-12']
  team_id char(36) [not null, ref: > teams.id]
  member_id char(36) [not null, ref: > users.id]
  monthly_revenue decimal(15,2) [not null, default: 0, note: 'CHECK >= 0']
  contract_count int [not null, default: 0, note: 'CHECK >= 0']
  company_count int [not null, default: 0, note: 'CHECK >= 0']
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    workspace_id [name: 'idx_performance_workspace']
    (year, month) [name: 'idx_performance_year_month']
    team_id [name: 'idx_performance_team']
    member_id [name: 'idx_performance_member']
    (workspace_id, year, month, team_id, member_id) [unique, name: 'idx_performance_unique']
  }

  Note: '성과 집계 - Cron으로 생성/갱신, CASCADE on FK deletes'
}

// ============================================
// 6. 멤버십 및 결제
// ============================================

Table payment_methods {
  id char(36) [pk, default: `UUID()`]
  user_id char(36) [not null, ref: > users.id]
  type "ENUM('card', 'bank_transfer')" [not null, default: 'card']
  card_last4 varchar(4)
  card_brand varchar(20) [note: 'Visa, Mastercard, ...']
  expiry_month int [note: 'CHECK 1-12']
  expiry_year int [note: 'CHECK >= 2020']
  billing_name varchar(100)
  pg_token varchar(500) [note: '암호화 필수!']
  is_default boolean [not null, default: false]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    user_id [name: 'idx_payment_methods_user']
    is_default [name: 'idx_payment_methods_default']
  }

  Note: '결제 수단 - CASCADE on user delete'
}

Table memberships {
  id char(36) [pk, default: `UUID()`]
  user_id char(36) [not null, unique, ref: - users.id]
  level "ENUM('BASIC', 'STANDARD', 'PREMIUM')" [not null, default: 'BASIC']
  status "ENUM('활성', '비활성', '만료')" [not null, default: '활성']
  start_date date [not null]
  end_date date [not null, note: 'CHECK > start_date']
  renewal_date date
  billing_cycle "ENUM('monthly', 'annual')" [not null]
  payment_method_id char(36) [ref: > payment_methods.id]
  price_monthly decimal(10,2) [not null, note: 'CHECK >= 0']
  price_annual decimal(10,2) [not null, note: 'CHECK >= 0']
  is_auto_renew boolean [not null, default: true]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    user_id [unique, name: 'idx_memberships_user']
    level [name: 'idx_memberships_level']
    status [name: 'idx_memberships_status']
    end_date [name: 'idx_memberships_end_date']
    payment_method_id [name: 'idx_memberships_payment_method']
  }

  Note: '멤버십 구독 - 1:1 with users, CASCADE on user delete'
}

Table payments {
  id char(36) [pk, default: `UUID()`]
  user_id char(36) [not null, ref: > users.id]
  membership_id char(36) [ref: > memberships.id]
  amount decimal(10,2) [not null, note: 'CHECK >= 0']
  currency varchar(3) [not null, default: 'KRW']
  method varchar(50) [not null]
  status "ENUM('완료', '진행중', '실패', '환불')" [not null, default: '진행중']
  product_name varchar(100) [not null]
  payment_date datetime [not null, default: `CURRENT_TIMESTAMP`]
  receipt_url varchar(500)
  pg_transaction_id varchar(100)
  failure_reason text
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    user_id [name: 'idx_payments_user']
    membership_id [name: 'idx_payments_membership']
    status [name: 'idx_payments_status']
    payment_date [name: 'idx_payments_date']
    pg_transaction_id [name: 'idx_payments_pg_txn']
  }

  Note: '결제 내역 - RESTRICT on user delete (이력 보존)'
}

// ============================================
// 7. 지원 기능
// ============================================

Table notices {
  id int [pk, increment]
  type "ENUM('공지', '이벤트', '업데이트')" [not null, default: '공지']
  title varchar(200) [not null]
  content text [not null, note: 'HTML or Markdown']
  author_id char(36) [not null, ref: > users.id]
  is_pinned boolean [not null, default: false]
  view_count int [not null, default: 0, note: 'CHECK >= 0']
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    type [name: 'idx_notices_type']
    (is_pinned, created_at) [name: 'idx_notices_pinned_created']
    author_id [name: 'idx_notices_author']
  }

  Note: '공지사항 - SET NULL on author delete'
}

Table inquiries {
  id char(36) [pk, default: `UUID()`]
  user_id char(36) [not null, ref: > users.id]
  subject varchar(200) [not null]
  category "ENUM('버그', '기능요청', '기타')" [not null, default: '기타']
  description text [not null]
  attachment_url varchar(500)
  status "ENUM('접수', '답변중', '완료')" [not null, default: '접수']
  response text
  responded_at datetime
  responder_id char(36) [ref: > users.id]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]
  updated_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    user_id [name: 'idx_inquiries_user']
    category [name: 'idx_inquiries_category']
    status [name: 'idx_inquiries_status']
    created_at [name: 'idx_inquiries_created']
    responder_id [name: 'idx_inquiries_responder']
  }

  Note: '고객 문의 - RESTRICT on user delete'
}

Table notifications {
  id char(36) [pk, default: `UUID()`]
  user_id char(36) [not null, ref: > users.id]
  type varchar(50) [not null, note: '계약만료, 업무완료, 순위변동 등']
  message text [not null]
  link_url varchar(500)
  is_read boolean [not null, default: false]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    (user_id, is_read) [name: 'idx_notifications_user_read']
    created_at [name: 'idx_notifications_created']
    type [name: 'idx_notifications_type']
  }

  Note: '사용자 알림 - CASCADE on user delete'
}

Table chat_messages {
  id char(36) [pk, default: `UUID()`]
  user_id char(36) [not null, ref: > users.id]
  sender_type "ENUM('user', 'bot', 'admin')" [not null]
  message text [not null]
  created_at datetime [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    (user_id, created_at) [name: 'idx_chat_messages_user_created']
    sender_type [name: 'idx_chat_messages_sender_type']
  }

  Note: '챗봇 메시지 - CASCADE on user delete'
}

// ============================================
// MariaDB 특화 주석
// ============================================

// UUID 생성: UUID() 함수 (MariaDB 10.7+) 또는 UUID_SHORT()
// ENUM: MariaDB 네이티브 지원
// JSON: MariaDB 10.2+
// Triggers: DELIMITER 사용
// Character Set: utf8mb4 (이모지 지원)
// Collation: utf8mb4_unicode_ci (다국어 정렬)
// Engine: InnoDB (트랜잭션, FK 지원)
// ON UPDATE CURRENT_TIMESTAMP: 자동 updated_at 갱신
